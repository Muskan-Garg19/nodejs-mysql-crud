<!DOCTYPE html>
<html lang="en">
<head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Users data</title>
      <style>
            table,td,th{
                  border-collapse:collapse;
                  border: 2px solid black;   
                  padding: 12px;
            }
      </style>
</head>
<body>
      <table>
            <tr>
                  <th> id </th>
                  <th> username </th>
                  <th> email </th>
            </tr>

            <% for(let i=0;i<result.length;i++){ %>
                  <tr>
                        <td> <%= result[i]["id"] %> </td>
                        <td> <%= result[i]["username"] %> </td>
                        <td> <%= result[i]["email"] %> </td>
                        <td>
                              <form action="/user/<%= result[i]["id"] %>/edit" method="get">
                                    <button>Edit Username</button>
                              </form>
                        </td>
                        <td>
                              <form action="/user/<%= result[i]["id"] %>?_method=DELETE" method="post">
                                    <button>Delete User</button>
                              </form>
                        </td>
                  </tr>
            <% } %>
      </table>
</body>
</html>